# Clerk public key — safe to expose to the browser.
# Get it from https://dashboard.clerk.com → API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk server-side secret key — only used in server functions/routes.
# Add this in Vercel's dashboard (do NOT commit it).
CLERK_SECRET_KEY=sk_test_...

# AWS SAM backend — API Gateway invoke URL.
# Set in Vercel after `sam deploy` (from the ApiUrl stack output).
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
